# SwiftPM build output
/.build/
/.swiftpm/
*.xcodeproj

# Built artifacts
*.dylib
*.o

# Captured sessions contain rig-specific names/IDs and live state.
# The repo is public; raw captures NEVER go in git. Only generic protocol
# findings get hand-copied into mcp-midi-controller/docs/research/<device>.md.
/captures/

# Private, installation-specific notes (real device/console names, IPs, MACs).
/private/
*.local.*

